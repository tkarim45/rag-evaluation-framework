# Copy to .env (gitignored) and fill in. Use an IAM user with Bedrock access — never root keys.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Model overrides — defaults live in src/config.py. Bedrock requires INFERENCE PROFILE ids
# (the global.* / us.* prefix) for Claude; bare model ids are rejected for on-demand use.
#
# GEN_MODEL    = pipeline-under-test answer model (cheap is fine — you're measuring retrieval)
# JUDGE_MODEL  = RAGAS metric scorer. KEEP THIS FIXED across all experiments or scores aren't comparable.
# EMBED_MODEL  = embeddings for ingest + RAGAS. amazon.titan-embed-text-v2:0 works on-demand (no profile).
#
# GEN_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# JUDGE_MODEL=global.anthropic.claude-sonnet-4-6
# EMBED_MODEL=amazon.titan-embed-text-v2:0
